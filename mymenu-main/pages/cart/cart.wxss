/* pages/cart/cart.wxss */
.cart-list {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.cart-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background-color: #f0f0f0;
  margin-right: 20rpx;
}

.cart-info {
  flex: 1;
}

.cart-name {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.cart-price {
  font-size: 28rpx;
  color: #ff6b35;
}

.quantity-control {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.qty-btn {
  width: 50rpx;
  height: 50rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.qty-btn:active {
  background-color: #e0e0e0;
}

.qty-num {
  margin: 0 20rpx;
  font-size: 30rpx;
  min-width: 40rpx;
  text-align: center;
}

.delete-btn {
  color: #999;
  font-size: 40rpx;
  padding: 10rpx;
}

/* 备注输入 */
.remark-section {
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 最后一个备注区域给底部固定栏留空间 */
.remark-section:last-of-type {
  margin-bottom: 130rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.remark-input {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.remark-input:focus {
  border-color: #ff6b35;
  background: #fff;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.total-info {
  font-size: 30rpx;
}

.total-price {
  font-size: 36rpx;
  color: #ff6b35;
  font-weight: bold;
}

.checkout-btn {
  background-color: #ff6b35;
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.checkout-btn:active {
  background-color: #e55a2b;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 70vh;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}

.go-menu {
  color: #ff6b35;
  font-size: 30rpx;
  padding: 20rpx 60rpx;
  border: 2rpx solid #ff6b35;
  border-radius: 40rpx;
}
