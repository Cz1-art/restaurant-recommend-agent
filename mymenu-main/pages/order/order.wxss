/* pages/order/order.wxss */
.container {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 标签栏样式 */
.category-scroll {
  white-space: nowrap;
  background-color: #fff;
  padding: 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.category-list {
  display: flex;
  gap: 20rpx;
}

.category-item {
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #ff6b35;
  color: #fff;
}

.order-list {
  padding: 20rpx;
}

.order-item {
  padding: 0;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fafafa;
}

.order-id {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 28rpx;
  font-weight: bold;
}

.status-pending { color: #ff6b35; }
.status-paid { color: #52c41a; }
.status-cancelled { color: #ff4d4f; }

.order-content {
  padding: 20rpx;
}

.order-dish {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  font-size: 28rpx;
}

.dish-total {
  color: #ff6b35;
}

.order-remark {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #fff8f5;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #ff6b35;
  border-left: 4rpx solid #ff6b35;
  word-break: break-all;
  line-height: 1.5;
  box-sizing: border-box;
  max-width: 100%;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fafafa;
}

.order-footer-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.order-footer-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-total {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.cancel-link {
  font-size: 24rpx;
  color: #ff4d4f;
  text-decoration: underline;
  padding: 4rpx 0;
}

.cancel-link:active {
  opacity: 0.6;
}

.pay-btn {
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff6b35, #ff8f5e);
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

.pay-btn:active, .review-btn:active {
  opacity: 0.85;
}

.review-btn {
  font-size: 24rpx; color: #fff;
  background: linear-gradient(135deg, #faad14, #ffc53d);
  padding: 10rpx 24rpx; border-radius: 30rpx; font-weight: bold;
}

/* 评价弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
}
.review-modal {
  position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);
  background: #fff; border-radius: 16rpx; padding: 32rpx;
  width: 85%; max-height: 70vh; overflow-y: auto; z-index: 101;
}
.review-title { font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 24rpx; }
.review-dish { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review-dish-name { font-size: 28rpx; font-weight: bold; margin-bottom: 8rpx; }
.review-stars { display: flex; gap: 8rpx; margin-bottom: 8rpx; }
.star { font-size: 40rpx; color: #ddd; }
.star.active { color: #faad14; }
.review-input { width: 100%; padding: 12rpx 16rpx; border: 1rpx solid #eee; border-radius: 8rpx; font-size: 26rpx; box-sizing: border-box; margin-bottom: 8rpx; }
.review-submit-btn { font-size: 24rpx; color: #fff; background: #faad14; padding: 10rpx 28rpx; border-radius: 20rpx; text-align: center; }
.review-close { text-align: center; padding: 20rpx; font-size: 26rpx; color: #999; }

.status-paid {
  color: #52c41a !important;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 底部工具栏 */
.order-bottom-bar {
  padding: 40rpx 0 60rpx;
  text-align: center;
}

.logout-btn {
  display: inline-block;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 48rpx;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
}

.logout-btn:active {
  background: #f5f5f5;
  color: #666;
}
