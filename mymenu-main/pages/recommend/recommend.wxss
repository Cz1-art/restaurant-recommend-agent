/* pages/recommend/recommend.wxss */

/* 顶部横幅 */
.banner {
  background: linear-gradient(135deg, #ff6b35, #ff8f5e);
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.banner-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.banner-icon {
  font-size: 80rpx;
}

.banner-icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner-chat-hint {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 6rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 板块 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-icon {
  margin-right: 8rpx;
}

.section-badge {
  background-color: #ff6b35;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.section-tag {
  background-color: #ff4757;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

/* 人气热销 - 横向滚动 */
.dish-scroll {
  white-space: nowrap;
  padding: 10rpx 20rpx;
}

.dish-scroll-inner {
  display: inline-flex;
  gap: 20rpx;
}

.dish-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}

.dish-card .dish-img {
  width: 240rpx;
  height: 200rpx;
  background-color: #f0f0f0;
}

.dish-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background: rgba(255,107,53,0.9);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.dish-card .dish-name {
  font-size: 28rpx;
  font-weight: bold;
  padding: 12rpx 16rpx 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-card .dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 16rpx 16rpx;
}

.dish-card .dish-price {
  font-size: 30rpx;
  color: #ff6b35;
  font-weight: bold;
}

.dish-card .add-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #ff6b35;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: bold;
}

.dish-card .add-btn:active {
  background-color: #e55a2b;
}

/* 猜你喜欢口味标签 */
.guess-flavor {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5e);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

/* 新品推荐 - 列表 */
.dish-list {
  padding: 0 20rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.dish-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
  margin-right: 20rpx;
}

.dish-info {
  flex: 1;
}

.dish-item .dish-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.dish-item .dish-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 340rpx;
}

.dish-item .dish-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.dish-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.flavor-tag {
  font-size: 20rpx;
  color: #ff6b35;
  background-color: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid #ffcdc0;
}

.rating-star {
  font-size: 20rpx;
  color: #faad14;
  font-weight: bold;
}

.dish-actions {
  margin-left: 20rpx;
}

.dish-item .add-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: #ff6b35;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
}

.dish-item .add-btn:active {
  background-color: #e55a2b;
}

/* 搭配推荐 */
.combo-list {
  padding: 0 20rpx;
}

.combo-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.combo-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.combo-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.combo-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.combo-dishes {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.combo-dish {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.combo-dish-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}

.combo-dish-name {
  font-size: 22rpx;
  color: #666;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.combo-action {
  text-align: center;
}

.combo-add-btn {
  display: inline-block;
  background: linear-gradient(135deg, #ff6b35, #ff8f5e);
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 40rpx;
  border-radius: 30rpx;
}

.combo-add-btn:active {
  opacity: 0.85;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.go-menu-btn {
  display: inline-block;
  margin-top: 30rpx;
  background-color: #ff6b35;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border-radius: 30rpx;
}

.go-menu-btn:active { opacity: 0.85; }

/* 桌号信息栏 */
.table-info-bar {
  display: flex; align-items: center; gap: 8rpx;
  margin: 16rpx 20rpx 0; padding: 16rpx 20rpx;
  background: #fff; border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.table-info-icon { font-size: 28rpx; }
.table-info-text { flex: 1; font-size: 28rpx; color: #333; font-weight: bold; }
.table-info-arrow { font-size: 32rpx; color: #ccc; }

/* 选桌弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
}
.table-picker-modal {
  position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);
  background: #fff; border-radius: 20rpx; padding: 48rpx 40rpx;
  width: 80%; text-align: center; z-index: 101;
}
.table-picker-title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.table-picker-sub { font-size: 26rpx; color: #999; margin-bottom: 36rpx; }
.table-picker-btn {
  display: inline-block; padding: 20rpx 80rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5e);
  color: #fff; border-radius: 40rpx; font-size: 30rpx; font-weight: bold;
}
.table-picker-btn.disabled { background: #ccc; }
.table-skip { margin-top: 24rpx; font-size: 26rpx; color: #999; padding: 16rpx; }
