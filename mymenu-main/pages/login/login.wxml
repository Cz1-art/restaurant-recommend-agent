<!-- pages/login/login.wxml -->
<view class="login-container">
  <view class="login-header">
    <text class="app-title">智能点餐系统</text>
    <text class="app-subtitle">{{isRegister ? '注册账号' : '欢迎登录'}}</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <text class="form-icon">👤</text>
      <input class="form-input" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput" />
    </view>

    <view class="form-item">
      <text class="form-icon">🔒</text>
      <input class="form-input" placeholder="请输入密码" password="{{true}}" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="form-item" wx:if="{{isRegister}}">
      <text class="form-icon">😊</text>
      <input class="form-input" placeholder="请输入昵称（选填）" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <button class="submit-btn" bindtap="submit">{{isRegister ? '注册' : '登录'}}</button>

    <view class="toggle-mode" bindtap="toggleMode">
      <text>{{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}</text>
    </view>
  </view>
</view>
