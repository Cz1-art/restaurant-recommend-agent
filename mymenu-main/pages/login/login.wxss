/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5e 100%);
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.app-title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.app-subtitle {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 24rpx 0;
  margin-bottom: 10rpx;
}

.form-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  height: 50rpx;
}

.submit-btn {
  margin-top: 50rpx;
  background-color: #ff6b35;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  height: 90rpx;
  line-height: 90rpx;
}

.submit-btn:active {
  background-color: #e55a2b;
}

.toggle-mode {
  text-align: center;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #ff6b35;
}
