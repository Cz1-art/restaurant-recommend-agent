/* pages/category/category.wxss */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  padding: 20rpx 0;
}

.category-list {
  margin-bottom: 30rpx;
}

.category-row {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 2rpx;
  border-radius: 8rpx;
}

.drag-handle {
  color: #ccc;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.category-name {
  flex: 1;
  font-size: 30rpx;
}

.category-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
}

.action-btn.edit {
  color: #ff6b35;
  background-color: #fff5f0;
}

.action-btn.delete {
  color: #ff4d4f;
  background-color: #fff1f0;
}

.add-category {
  text-align: center;
  padding: 30rpx;
  color: #ff6b35;
  font-size: 30rpx;
  border: 2rpx dashed #ff6b35;
  background-color: #fff;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 80%;
  z-index: 101;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background-color: #ff6b35;
  color: #fff;
}
